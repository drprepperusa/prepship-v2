{
  "name": "prepshipv2",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "prepshipv2",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/api": {
      "name": "@prepshipv2/api"
    },
    "apps/web": {
      "name": "@prepshipv2/web"
    },
    "apps/worker": {
      "name": "@prepshipv2/worker"
    },
    "node_modules/@prepshipv2/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@prepshipv2/contracts": {
      "resolved": "packages/contracts",
      "link": true
    },
    "node_modules/@prepshipv2/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@prepshipv2/web": {
      "resolved": "apps/web",
      "link": true
    },
    "node_modules/@prepshipv2/worker": {
      "resolved": "apps/worker",
      "link": true
    },
    "packages/contracts": {
      "name": "@prepshipv2/contracts"
    },
    "packages/shared": {
      "name": "@prepshipv2/shared"
    }
  }
}
