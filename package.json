{
  "name": "prepshipv2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "node --experimental-strip-types apps/api/src/main.ts",
    "dev:react": "npm run dev --workspace apps/react",
    "dev:web": "node --experimental-strip-types apps/web/src/main.ts",
    "dev:worker": "node --experimental-strip-types apps/worker/src/main.ts",
    "build:react": "npm run build --workspace apps/react",
    "test": "node --experimental-strip-types --test apps/api/test/*.test.ts apps/web/test/*.test.ts apps/react/test/*.test.ts"
  },
  "dependencies": {
    "express": "^5.2.1",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
