# Core runtime
DB_PROVIDER=sqlite
SQLITE_DB_PATH=/srv/prepship/prepship.db
PREPSHIP_SECRETS_PATH=/srv/prepshipv2/config/secrets.json
PREPSHIP_V1_ROOT=/srv/prepship
PREPSHIP_WEB_PUBLIC_DIR=/srv/prepshipv2/apps/web/public
REACT_PORT=4014

# Ports
API_PORT=4010
WEB_PORT=4011

# Keep disabled during parity testing unless you intentionally cut process ownership over to the V2 worker.
WORKER_SYNC_ENABLED=false

# Optional if the web process should proxy to a different API origin.
API_BASE_URL=http://127.0.0.1:4010

# Optional if the V3 React app should proxy to a different API origin.
VITE_API_PROXY_TARGET=http://127.0.0.1:4010
